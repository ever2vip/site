<%- include('../partials/head') %><%- include('../partials/nav') %><%- include('../partials/flash') %>
<main class="luxury-bg pt-32"><section class="mx-auto max-w-7xl px-5 py-20 lg:px-8"><p class="text-xs uppercase tracking-[0.3em] text-clubRed">VIP Desk</p><h1 class="mt-4 font-sync text-4xl uppercase md:text-6xl">Contact</h1><div class="mt-12 grid gap-10 lg:grid-cols-2"><form action="/contact" method="POST" class="glass-card rounded-xl p-8"><input type="hidden" name="_csrf" value="<%= csrfToken %>"><label class="admin-label">Name</label><input name="name" required class="admin-input mb-4"><label class="admin-label">Email</label><input name="email" type="email" required class="admin-input mb-4"><label class="admin-label">Subject</label><input name="subject" class="admin-input mb-4" value="VIP Booking Inquiry"><label class="admin-label">Message</label><textarea name="message" rows="6" required class="admin-input mb-6"></textarea><button class="rounded-full bg-clubRed px-8 py-4 text-xs uppercase tracking-[.22em]">Send Inquiry</button></form><div class="glass-card rounded-xl p-8"><h2 class="font-sync text-2xl uppercase">Dubai, UAE</h2><p class="mt-5 text-clubMuted"><%= content.contact_email || 'info@pleasureclub.com' %><br><%= content.contact_phone || '+971 50 123 4567' %></p><div class="mt-8 flex h-80 items-center justify-center border border-clubRed/30 bg-[radial-gradient(circle,rgba(230,0,0,.22),transparent_35%),#080808]"><p class="font-sync text-clubRed">Interactive Map Style</p></div></div></div></section></main><%- include('../partials/footer') %>
