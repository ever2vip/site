<%- include('../partials/head') %><%- include('../partials/nav') %><%- include('../partials/flash') %>
<main class="luxury-bg pt-32"><section class="mx-auto max-w-7xl px-5 py-16 lg:px-8"><p class="text-xs uppercase tracking-[0.3em] text-clubRed">Privileges</p><h1 class="mt-4 font-sync text-4xl uppercase md:text-6xl">Membership</h1><p class="mt-6 max-w-2xl text-clubMuted">A private path into curated access, discreet service, and rare cultural evenings.</p><div class="mt-14 grid gap-8 md:grid-cols-3"><% memberships.forEach(m=>{ %><article class="glass-card rounded-xl p-8 <%= m.isHighlighted?'pulse-glow border-clubRed':'' %>"><h2 class="font-sync text-xl uppercase"><%= m.name %></h2><p class="mt-5 text-3xl text-clubRed"><%= m.currency %><%= m.price %><span class="text-sm text-clubMuted">/<%= m.period %></span></p><ul class="mt-8 space-y-4 text-sm text-clubMuted"><% m.features.forEach(f=>{ %><li>✓ <%= f %></li><% }) %></ul></article><% }) %></div><div id="application" class="mt-20 grid gap-10 lg:grid-cols-2"><div><h2 class="font-sync text-3xl uppercase">Apply for Access</h2><p class="mt-5 text-clubMuted">Applications are privately reviewed by the membership office.</p></div><form action="/membership/apply" method="POST" class="glass-card rounded-xl p-8"><input type="hidden" name="_csrf" value="<%= csrfToken %>"><label class="admin-label">Full Name</label><input name="fullName" required class="admin-input mb-4"><label class="admin-label">Email</label><input type="email" name="email" required class="admin-input mb-4"><label class="admin-label">Phone</label><input name="phone" class="admin-input mb-4"><label class="admin-label">Desired Tier</label><select name="tier" class="admin-input mb-4"><% memberships.forEach(m=>{ %><option><%= m.name %></option><% }) %></select><label class="admin-label">Message</label><textarea name="message" class="admin-input mb-6" rows="4"></textarea><button class="red-btn rounded-full bg-clubRed px-8 py-4 text-xs uppercase tracking-[.22em]">Submit Application</button></form></div></section></main><%- include('../partials/footer') %>
