<%- include('../partials/head') %><%- include('../partials/nav') %><%- include('../partials/flash') %>
<main class="bg-clubBlack pt-32"><section class="mx-auto max-w-7xl px-5 py-16 lg:px-8"><p class="text-xs uppercase tracking-[0.3em] text-clubRed">Impressions</p><h1 class="mt-4 font-sync text-4xl uppercase md:text-6xl">Gallery</h1><div class="mt-12 grid grid-cols-1 gap-5 sm:grid-cols-2 lg:grid-cols-3"><% media.forEach(m=>{ %><div class="group relative overflow-hidden border border-white/10"><% if(m.type==='video'){ %><video src="<%= m.url %>" controls class="h-80 w-full object-cover"></video><% } else { %><img data-lightbox data-src="<%= m.url %>" src="<%= m.url %>" class="h-80 w-full cursor-pointer object-cover opacity-80 transition group-hover:scale-105 group-hover:opacity-100"><% } %><div class="absolute bottom-0 inset-x-0 bg-gradient-to-t from-black p-5"><p class="text-sm uppercase tracking-widest"><%= m.title %></p></div></div><% }) %></div></section><div id="lightbox" class="lightbox"><img id="lightboxImg" src="" alt="Expanded gallery image"></div></main><%- include('../partials/footer') %>
