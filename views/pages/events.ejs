<%- include('../partials/head') %><%- include('../partials/nav') %><%- include('../partials/flash') %>
<main class="luxury-bg pt-32"><section class="mx-auto max-w-7xl px-5 py-16 lg:px-8"><p class="text-xs uppercase tracking-[0.3em] text-clubRed">Calendar</p><h1 class="mt-4 font-sync text-4xl uppercase md:text-6xl">Events</h1><p class="mt-6 max-w-2xl text-clubMuted">Curated evenings, masked rituals, private salons, and unforgettable midnight experiences.</p><h2 class="mt-16 font-sync text-2xl uppercase">Upcoming Events</h2><div class="mt-8 grid gap-8 md:grid-cols-3"><% upcoming.forEach(e=>{ %><article class="glass-card overflow-hidden rounded-xl"><img src="<%= e.posterUrl %>" class="h-72 w-full object-cover"><div class="p-6"><p class="text-xs text-clubRed"><%= e.startsAt.toDateString() %></p><h3 class="mt-3 font-sync text-lg"><%= e.title %></h3><p class="mt-4 text-sm leading-6 text-clubMuted"><%= e.description %></p><p class="mt-4 text-sm text-clubMuted">⌖ <%= e.location %></p></div></article><% }) %></div><h2 class="mt-20 font-sync text-2xl uppercase">Past Events</h2><div class="mt-8 grid gap-8 md:grid-cols-3"><% past.forEach(e=>{ %><article class="glass-card overflow-hidden rounded-xl opacity-75"><img src="<%= e.posterUrl %>" class="h-64 w-full object-cover grayscale"><div class="p-6"><p class="text-xs text-clubMuted"><%= e.startsAt.toDateString() %></p><h3 class="mt-3 font-sync text-lg"><%= e.title %></h3><p class="mt-4 text-sm leading-6 text-clubMuted"><%= e.description %></p></div></article><% }) %></div></section></main><%- include('../partials/footer') %>
