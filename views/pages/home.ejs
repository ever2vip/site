<%- include('../partials/head') %><%- include('../partials/nav') %><%- include('../partials/flash') %>
<main style="--hero-url:url('<%= content.hero_image || 'https://images.unsplash.com/photo-1519671482749-fd09be7ccebf?auto=format&fit=crop&w=1800&q=90' %>');--glow:<%= settings.glowIntensity || 35 %>">
<section class="hero-image relative flex min-h-screen items-center overflow-hidden"><div class="absolute inset-0 bg-[radial-gradient(circle_at_65%_42%,rgba(230,0,0,0.24),transparent_28%)]"></div><div class="absolute bottom-0 left-0 right-0 h-40 bg-gradient-to-t from-clubBlack to-transparent"></div><div class="relative z-10 mx-auto grid w-full max-w-7xl grid-cols-1 items-center gap-10 px-5 pt-28 lg:grid-cols-2 lg:px-8"><div class="fade-up max-w-xl"><p class="mb-5 text-xs uppercase tracking-[0.35em] text-clubMuted"><%= content.hero_kicker || 'Welcome To' %></p><h1 class="font-sync text-5xl font-bold tracking-tight text-clubRed sm:text-6xl lg:text-7xl"><%= content.hero_title || 'Pleasure' %></h1><h2 class="mt-3 font-sync text-2xl tracking-[0.08em] text-white/90 sm:text-3xl"><%= content.hero_subtitle || 'Private Club' %></h2><div class="my-7 h-px w-64 bg-gradient-to-r from-transparent via-clubRed/60 to-transparent"></div><p class="max-w-sm text-sm leading-7 text-clubMuted"><%= content.hero_description || 'An exclusive world of luxury, passion, and extraordinary experiences. Not for everyone. Only for chosen ones.' %></p><a href="/events" class="red-btn mt-9 inline-flex rounded-full border border-clubRed/75 px-8 py-4 text-[11px] uppercase tracking-[0.22em] hover:bg-clubRed">Discover More</a></div><div class="fade-up hidden min-h-[560px] items-center justify-center lg:flex"><button class="flex h-24 w-24 items-center justify-center rounded-full border border-white/60 bg-black/20 shadow-redGlow backdrop-blur-md"><span class="ml-1 h-0 w-0 border-y-[15px] border-l-[24px] border-y-transparent border-l-white"></span></button></div></div></section>
<% if (featuredEvent) { %><section class="luxury-bg border-t border-white/10 py-24"><div class="mx-auto max-w-7xl px-5 lg:px-8"><div class="mb-8 flex items-center gap-6"><p class="text-xs uppercase tracking-[0.25em] text-clubRed">Upcoming Event</p><div class="h-px flex-1 bg-white/10"></div></div><div class="grid items-center gap-12 lg:grid-cols-2"><img src="<%= featuredEvent.posterUrl || 'https://images.unsplash.com/photo-1515168833906-d2a3b82b3029?auto=format&fit=crop&w=900&q=90' %>" class="fade-up mx-auto aspect-square max-w-lg border border-red-950/70 object-cover shadow-softRed" alt="<%= featuredEvent.title %>"><div class="fade-up"><span class="mb-5 inline-flex border border-clubRuby/70 bg-clubRuby/20 px-4 py-1 text-[10px] uppercase tracking-[0.22em] text-clubRed">Exclusive Event</span><h2 class="font-sync text-3xl uppercase md:text-4xl"><%= featuredEvent.title %></h2><p class="mt-6 max-w-md text-sm leading-7 text-clubMuted"><%= featuredEvent.description %></p><div id="countdown" data-target="<%= featuredEvent.startsAt.toISOString() %>" class="mt-9 grid grid-cols-4 gap-4 text-center sm:max-w-xl"><% ['days','hours','minutes','seconds'].forEach(function(id){ %><div><p id="<%= id %>" class="text-4xl font-light text-clubRed sm:text-5xl">00</p><p class="mt-2 text-[10px] uppercase tracking-widest text-clubMuted"><%= id %></p></div><% }) %></div><div class="mt-9 space-y-5 text-sm text-clubMuted"><p>□ <%= featuredEvent.startsAt.toDateString() %></p><p>◷ <%= featuredEvent.startsAt.toLocaleTimeString([], {hour:'2-digit', minute:'2-digit'}) %></p><p>⌖ <%= featuredEvent.location %></p></div><a href="/events" class="red-btn mt-10 inline-flex rounded-full border border-clubRed/80 px-8 py-4 text-[11px] uppercase tracking-[0.22em] hover:bg-clubRed">View Event Details</a></div></div></div></section><% } %>
<section class="bg-clubBlack py-24"><div class="mx-auto max-w-7xl px-5 lg:px-8"><div class="fade-up mx-auto mb-12 max-w-3xl text-center"><p class="mb-4 text-xs uppercase tracking-[0.3em] text-clubRed">Membership Packages</p><h2 class="font-sync text-2xl uppercase md:text-4xl">Choose Your Privilege</h2><p class="mt-5 text-sm text-clubMuted">Exclusive access. Premium benefits. Unmatched experiences.</p></div><div class="grid gap-8 md:grid-cols-3"><% memberships.forEach(function(m){ %><article class="fade-up glass-card rounded-xl p-8 <%= m.isHighlighted ? 'pulse-glow border-clubRed md:-translate-y-4' : '' %>"><% if(m.badge){ %><span class="rounded bg-clubRuby/40 px-4 py-1 text-[9px] uppercase tracking-[0.22em] text-clubRed"><%= m.badge %></span><% } %><h3 class="mt-5 font-sync text-xl uppercase"><%= m.name %></h3><p class="mt-5 text-2xl text-clubRed"><%= m.currency %><%= m.price %> <span class="text-xs text-clubMuted">/ <%= m.period %></span></p><ul class="mt-8 space-y-5 text-sm text-clubMuted"><% m.features.forEach(f=>{ %><li class="flex gap-3"><span class="text-clubRed">✓</span><%= f %></li><% }) %></ul><a href="/membership#application" class="red-btn mt-10 inline-flex w-full justify-center rounded-full <%= m.isHighlighted?'bg-clubRed':'border border-clubRed/60' %> px-6 py-4 text-[11px] uppercase tracking-[0.22em]">Join Now</a></article><% }) %></div></div></section>
<section class="border-y border-white/10 bg-[#070707] py-24"><div class="mx-auto max-w-7xl px-5 lg:px-8"><div class="fade-up mb-10 text-center"><p class="mb-4 text-xs uppercase tracking-[0.3em] text-clubRed">Impressions</p><h2 class="font-sync text-2xl uppercase md:text-4xl">A Glimpse Into Our World</h2></div><div id="carousel" class="carousel-track flex gap-5 overflow-x-auto px-2 py-4"><% gallery.forEach(g=>{ %><img src="<%= g.url %>" class="h-56 min-w-[280px] rounded-sm border border-white/10 object-cover opacity-85 md:min-w-[360px]" alt="<%= g.alt || g.title %>"><% }) %></div></div></section>
<section class="bg-gradient-to-r from-[#100707] via-clubBlack to-[#160707] py-24"><div class="mx-auto grid max-w-7xl items-center gap-12 px-5 lg:grid-cols-2 lg:px-8"><div><p class="mb-5 text-xs uppercase tracking-[0.3em] text-clubRed">Stay Connected</p><h2 class="font-sync text-3xl uppercase md:text-4xl">Join Our Exclusive List</h2><p class="mt-6 text-sm text-clubMuted">Be the first to receive invitations, updates, and exclusive offers.</p><form action="/subscribe" method="POST" class="mt-9 max-w-xl"><input type="hidden" name="_csrf" value="<%= csrfToken %>"><div class="flex overflow-hidden rounded-full border border-clubRed/40 bg-black/40 p-1"><input name="email" type="email" required placeholder="Enter your email" class="min-h-14 flex-1 bg-transparent px-6 text-sm outline-none"><button class="rounded-full bg-clubRed px-8 py-4 text-[11px] uppercase tracking-[0.22em]">Subscribe</button></div></form></div><div class="h-72 max-w-md rotate-[-7deg] border border-red-950/70 bg-[#111] shadow-softRed"><div class="flex h-full items-end justify-end p-8"><div class="text-right"><p class="font-sync text-2xl uppercase">You’re</p><p class="font-sync text-3xl uppercase text-clubRed">Invited</p></div></div></div></div></section>
</main><%- include('../partials/footer') %>
