<%- include('../partials/adminHead') %><%- include('../partials/adminNav') %><h1 class="font-sync text-3xl uppercase">Content & Dynamic Effects</h1><p class="mt-3 text-clubMuted">Edit visible copy, imagery URLs, glow intensity, animation toggles, and layout behavior.</p><form action="/admin/content" method="POST" class="mt-8 space-y-8"><input type="hidden" name="_csrf" value="<%= csrfToken %>"><section class="glass-card rounded-xl p-6"><h2 class="font-sync text-xl">Text Content</h2><div class="mt-6 grid gap-5 md:grid-cols-2"><% blocks.forEach(b=>{ %><div><label class="admin-label"><%= b.page %> · <%= b.label %></label><% if(b.type==='textarea' || b.type==='html'){ %><textarea name="blocks[<%= b.key %>]" rows="4" class="admin-input"><%= b.value %></textarea><% } else { %><input name="blocks[<%= b.key %>]" value="<%= b.value %>" class="admin-input"><% } %></div><% }) %></div></section><section class="glass-card rounded-xl p-6"><h2 class="font-sync text-xl">Effects & Layout</h2><div class="mt-6 grid gap-5 md:grid-cols-3"><% settings.forEach(s=>{ %><div><label class="admin-label"><%= s.label || s.key %></label><input name="settings[<%= s.key %>]" value="<%= s.value %>" class="admin-input"></div><% }) %></div></section><button class="rounded-full bg-clubRed px-8 py-4 text-xs uppercase tracking-[.22em]">Save All Changes</button></form><%- include('../partials/adminFooter') %>
