<%- include('../partials/adminHead') %><%- include('../partials/adminNav') %><h1 class="font-sync text-3xl uppercase">Applications & Inquiries</h1><div class="mt-8 grid gap-8 lg:grid-cols-2"><section class="glass-card rounded-xl p-6"><h2 class="font-sync text-xl">Membership Applications</h2><div class="mt-5 space-y-4"><% applications.forEach(a=>{ %><div class="border-b border-white/10 pb-4"><p class="font-semibold"><%= a.fullName %> · <span class="text-clubRed"><%= a.tier %></span></p><p class="text-sm text-clubMuted"><%= a.email %> · <%= a.phone %></p><p class="mt-2 text-sm text-clubMuted"><%= a.message %></p></div><% }) %></div></section><section class="glass-card rounded-xl p-6"><h2 class="font-sync text-xl">VIP Inquiries</h2><div class="mt-5 space-y-4"><% inquiries.forEach(i=>{ %><div class="border-b border-white/10 pb-4"><p class="font-semibold"><%= i.name %> · <span class="text-clubRed"><%= i.subject %></span></p><p class="text-sm text-clubMuted"><%= i.email %></p><p class="mt-2 text-sm text-clubMuted"><%= i.message %></p></div><% }) %></div></section></div><%- include('../partials/adminFooter') %>
