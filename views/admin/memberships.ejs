<%- include('../partials/adminHead') %><%- include('../partials/adminNav') %><h1 class="font-sync text-3xl uppercase">Memberships</h1><div class="mt-8 grid gap-8 lg:grid-cols-2"><form action="/admin/memberships" method="POST" class="glass-card rounded-xl p-6"><input type="hidden" name="_csrf" value="<%= csrfToken %>"><h2 class="font-sync text-xl">Create Tier</h2><label class="admin-label mt-4">Name</label><input name="name" class="admin-input" required><label class="admin-label mt-4">Price</label><input name="price" type="number" class="admin-input" required><label class="admin-label mt-4">Features, one per line</label><textarea name="features" rows="6" class="admin-input"></textarea><label class="admin-label mt-4">Badge</label><input name="badge" class="admin-input"><label class="mt-4 flex gap-2"><input name="isHighlighted" type="checkbox"> Highlight</label><button class="mt-5 rounded-full bg-clubRed px-6 py-3 text-xs uppercase tracking-widest">Create</button></form><div class="space-y-5"><% memberships.forEach(m=>{ %><form action="/admin/memberships/<%= m._id %>?_method=PUT" method="POST" class="glass-card rounded-xl p-6"><input type="hidden" name="_csrf" value="<%= csrfToken %>"><div class="grid gap-3 md:grid-cols-3"><input name="name" value="<%= m.name %>" class="admin-input"><input name="price" type="number" value="<%= m.price %>" class="admin-input"><input name="sortOrder" type="number" value="<%= m.sortOrder %>" class="admin-input"></div><textarea name="features" rows="5" class="admin-input mt-3"><%= m.features.join('\n') %></textarea><input name="badge" value="<%= m.badge %>" class="admin-input mt-3"><label class="mt-3 flex gap-2"><input name="isHighlighted" type="checkbox" <%= m.isHighlighted?'checked':'' %>> Highlight</label><button class="mt-4 text-clubRed">Save</button></form><form method="POST" action="/admin/memberships/<%= m._id %>?_method=DELETE"><input type="hidden" name="_csrf" value="<%= csrfToken %>"><button class="text-red-400">Delete <%= m.name %></button></form><% }) %></div></div><%- include('../partials/adminFooter') %>
