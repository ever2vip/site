<%- include('../partials/adminHead') %><%- include('../partials/adminNav') %><div class="flex flex-wrap items-center justify-between gap-4"><div><h1 class="font-sync text-3xl uppercase">Newsletter</h1><p class="mt-3 text-clubMuted">Manage subscribers, export CSV, and simulate exclusive invitation campaigns.</p></div><a href="/admin/subscribers/export" class="rounded-full border border-clubRed px-5 py-3 text-xs uppercase tracking-widest text-clubRed">Export CSV</a></div><form action="/admin/subscribers/simulate-email" method="POST" class="glass-card mt-8 rounded-xl p-6"><input type="hidden" name="_csrf" value="<%= csrfToken %>"><h2 class="font-sync text-xl">Invitation Email Simulator</h2><input name="subject" placeholder="Subject" class="admin-input mt-5"><textarea name="body" rows="7" placeholder="Rich invitation copy. Connect an email provider to send for real." class="admin-input mt-4"></textarea><button class="mt-5 rounded-full bg-clubRed px-6 py-3 text-xs uppercase tracking-widest">Simulate Send</button></form><div class="glass-card mt-8 rounded-xl p-6 overflow-auto"><table class="w-full"><tr><th class="table-cell text-left">Email</th><th class="table-cell text-left">Source</th><th class="table-cell text-left">Joined</th><th class="table-cell"></th></tr><% subscribers.forEach(s=>{ %><tr><td class="table-cell"><%= s.email %></td><td class="table-cell"><%= s.source %></td><td class="table-cell"><%= s.createdAt.toDateString() %></td><td class="table-cell"><form method="POST" action="/admin/subscribers/<%= s._id %>?_method=DELETE"><input type="hidden" name="_csrf" value="<%= csrfToken %>"><button class="text-red-400">Delete</button></form></td></tr><% }) %></table></div><%- include('../partials/adminFooter') %>
