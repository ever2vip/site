<%- include('../partials/adminHead') %><%- include('../partials/adminNav') %><h1 class="font-sync text-3xl uppercase">Media Manager</h1><form action="/admin/media" method="POST" enctype="multipart/form-data" class="glass-card mt-8 rounded-xl p-6"><input type="hidden" name="_csrf" value="<%= csrfToken %>"><div class="grid gap-4 md:grid-cols-5"><input name="title" placeholder="Title" class="admin-input"><input name="alt" placeholder="Alt text" class="admin-input"><select name="usage" class="admin-input"><option>general</option><option>hero</option><option>event</option><option>gallery</option><option>newsletter</option></select><input name="media" type="file" required class="admin-input"><button class="rounded-xl bg-clubRed px-5 py-3 text-xs uppercase tracking-widest">Upload</button></div></form><div class="mt-8 grid gap-5 sm:grid-cols-2 lg:grid-cols-4"><% media.forEach(m=>{ %><div class="glass-card overflow-hidden rounded-xl"><% if(m.type==='video'){ %><video src="<%= m.url %>" controls class="h-48 w-full object-cover"></video><% } else { %><img src="<%= m.url %>" class="h-48 w-full object-cover"><% } %><div class="p-4"><p class="font-semibold"><%= m.title %></p><p class="text-xs text-clubMuted"><%= m.usage %> · <%= m.type %></p><input readonly value="<%= m.url %>" class="admin-input mt-3 text-xs"><form method="POST" action="/admin/media/<%= m._id %>?_method=DELETE" class="mt-3"><input type="hidden" name="_csrf" value="<%= csrfToken %>"><button class="text-sm text-red-400">Delete</button></form></div></div><% }) %></div><%- include('../partials/adminFooter') %>
