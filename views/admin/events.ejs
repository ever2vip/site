<%- include('../partials/adminHead') %><%- include('../partials/adminNav') %><h1 class="font-sync text-3xl uppercase">Event Management</h1><div class="mt-8 grid gap-8 lg:grid-cols-2"><form action="<%= editEvent ? '/admin/events/'+editEvent._id+'?_method=PUT' : '/admin/events' %>" method="POST" enctype="multipart/form-data" class="glass-card rounded-xl p-6"><input type="hidden" name="_csrf" value="<%= csrfToken %>"><h2 class="font-sync text-xl"><%= editEvent?'Edit':'Create' %> Event</h2><label class="admin-label mt-5">Title</label><input name="title" value="<%= editEvent?.title || '' %>" required class="admin-input"><label class="admin-label mt-4">Description</label><textarea name="description" required rows="4" class="admin-input"><%= editEvent?.description || '' %></textarea><label class="admin-label mt-4">Date & Time</label><input name="startsAt" type="datetime-local" value="<%= editEvent ? new Date(editEvent.startsAt).toISOString().slice(0,16) : '' %>" required class="admin-input"><label class="admin-label mt-4">Location</label><input name="location" value="<%= editEvent?.location || '' %>" required class="admin-input"><label class="admin-label mt-4">Poster URL or Select Existing</label><select name="posterUrl" class="admin-input"><option value="<%= editEvent?.posterUrl || '' %>"><%= editEvent?.posterUrl || 'No poster' %></option><% media.forEach(m=>{ %><option value="<%= m.url %>"><%= m.title %></option><% }) %></select><label class="admin-label mt-4">Or Upload Poster</label><input name="posterFile" type="file" class="admin-input"><div class="mt-4 grid gap-4 md:grid-cols-3"><select name="status" class="admin-input"><% ['upcoming','past','draft'].forEach(s=>{ %><option <%= editEvent?.status===s?'selected':'' %>><%= s %></option><% }) %></select><label class="flex items-center gap-2 text-sm"><input name="countdownEnabled" type="checkbox" <%= editEvent?.countdownEnabled!==false?'checked':'' %>> Countdown</label><label class="flex items-center gap-2 text-sm"><input name="isFeatured" type="checkbox" <%= editEvent?.isFeatured?'checked':'' %>> Featured</label></div><button class="mt-6 rounded-full bg-clubRed px-6 py-3 text-xs uppercase tracking-widest">Save Event</button></form><div class="glass-card rounded-xl p-6"><h2 class="font-sync text-xl">All Events</h2><div class="mt-5 overflow-auto"><table class="w-full"><% events.forEach(e=>{ %><tr><td class="table-cell"><%= e.title %><br><span class="text-xs"><%= e.status %> · <%= new Date(e.startsAt).toDateString() %></span></td><td class="table-cell"><a class="text-clubRed" href="/admin/events/<%= e._id %>/edit">Edit</a></td><td class="table-cell"><form method="POST" action="/admin/events/<%= e._id %>?_method=DELETE"><input type="hidden" name="_csrf" value="<%= csrfToken %>"><button class="text-red-400">Delete</button></form></td></tr><% }) %></table></div></div></div><%- include('../partials/adminFooter') %>
