<header id="siteHeader" class="fixed inset-x-0 top-0 z-50 transition-all duration-300">
  <nav class="mx-auto flex max-w-7xl items-center justify-between px-5 py-5 lg:px-8">
    <a href="/" class="flex items-center gap-3"><%- include('logo') %></a>
    <button id="menuBtn" class="lg:hidden rounded-full border border-red-900/60 px-4 py-2 text-xs tracking-widest">MENU</button>
    <div id="navMenu" class="hidden absolute left-5 right-5 top-20 rounded-2xl border border-white/10 bg-black/95 p-6 lg:static lg:flex lg:items-center lg:gap-10 lg:border-0 lg:bg-transparent lg:p-0">
      <div class="flex flex-col gap-5 text-xs uppercase tracking-[0.22em] text-clubMuted lg:flex-row lg:items-center">
        <a class="hover:text-clubRed <%= path==='/'?'text-clubRed':'' %>" href="/">Home</a>
        <a class="hover:text-clubRed <%= path==='/events'?'text-clubRed':'' %>" href="/events">Events</a>
        <a class="hover:text-clubRed <%= path==='/membership'?'text-clubRed':'' %>" href="/membership">Membership</a>
        <a class="hover:text-clubRed <%= path==='/gallery'?'text-clubRed':'' %>" href="/gallery">Gallery</a>
        <a class="hover:text-clubRed <%= path==='/about'?'text-clubRed':'' %>" href="/about">About</a>
        <a class="hover:text-clubRed <%= path==='/contact'?'text-clubRed':'' %>" href="/contact">Contact</a>
      </div>
    </div>
    <a href="/admin" class="red-btn hidden rounded-full border border-clubRed/70 px-7 py-3 text-[11px] uppercase tracking-[0.22em] text-clubRed hover:bg-clubRed hover:text-white lg:inline-flex">Member Login</a>
  </nav>
</header>
